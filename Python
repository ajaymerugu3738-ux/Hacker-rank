def count_substring(string, sub_string):
    count = 0
    # Loop through the string up to the point where the substring could still fit
    for i in range(0, len(string) - len(sub_string) + 1):
        # Extract a slice of the string the same length as the substring
        # and compare it to the substring
        if string[i:i+len(sub_string)] == sub_string:
            count += 1
    return count
