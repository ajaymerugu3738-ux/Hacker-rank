from itertools import product

def solve():
    # Read K and M
    k, m = map(int, input().split())
    
    lists = []
    for _ in range(k):
        # Read the list, skipping the first element (which is the count Ni)
        row = list(map(int, input().split()))[1:]
        # We only care about the squares of these numbers
        lists.append([x**2 for x in row])
    
    max_val = 0
    
    # Generate all combinations of picking one squared value from each list
    for combination in product(*lists):
        # Calculate (sum of squares) % M
        current_sum = sum(combination) % m
        
        # Update max_val if the current combination is higher
        if current_sum > max_val:
            max_val = current_sum
            
    print(max_val)

if __name__ == '__main__':
    solve()
