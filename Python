from collections import Counter

def calculate_earnings():
    # Read the number of shoes (X)
    num_shoes = int(input())
    
    # Read the list of shoe sizes and convert to a Counter (inventory)
    shoe_sizes = list(map(int, input().split()))
    inventory = Counter(shoe_sizes)
    
    # Read the number of customers (N)
    num_customers = int(input())
    
    total_earned = 0
    
    # Process each customer's request
    for _ in range(num_customers):
        size, price = map(int, input().split())
        
        # Check if the desired size is in stock
        if inventory[size] > 0:
            total_earned += price
            # Reduce the inventory for that size by 1
            inventory[size] -= 1
            
    print(total_earned)

if __name__ == '__main__':
    calculate_earnings()
